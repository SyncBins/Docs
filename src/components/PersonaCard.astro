---
/**
 * Persona card for the landing page. A richer alternative to Starlight's
 * <LinkCard> when we want an eyebrow + multi-line description + arrow.
 *
 * Usage:
 *   <PersonaCard
 *     eyebrow="A · For users"
 *     title="I just want to use it"
 *     description="Signed up? Start here."
 *     href="/get-started/welcome/"
 *   />
 */
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  href: string;
}
const { eyebrow, title, description, href } = Astro.props;
---

<a class="sb-persona" href={href}>
  <span class="sb-persona__eyebrow">{eyebrow}</span>
  <h3 class="sb-persona__title">{title}</h3>
  <p class="sb-persona__desc">{description}</p>
  <span class="sb-persona__cta">
    Open
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14M13 5l7 7-7 7"/>
    </svg>
  </span>
</a>

<style is:global>
  .sb-persona {
    display: flex;
    flex-direction: column;
    padding: 22px;
    background: linear-gradient(180deg, var(--sb-bg-2), var(--sb-bg-1));
    border: 1px solid var(--sb-line-1);
    border-radius: var(--sb-r-l);
    text-decoration: none !important;
    color: inherit !important;
    transition: border-color .15s, transform .15s, box-shadow .15s;
    height: 100%;
    border-bottom: 1px solid var(--sb-line-1) !important;
  }
  .sb-persona:hover {
    border-color: var(--sb-acc-soft-2);
    transform: translateY(-2px);
    box-shadow: 0 16px 40px -16px oklch(0.4 0.1 var(--sb-acc-h) / .25);
  }
  .sb-persona__eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sb-acc);
    margin-bottom: 14px;
  }
  .sb-persona__title {
    font-size: 18px !important;
    font-weight: 600 !important;
    letter-spacing: -0.015em;
    color: var(--sb-ink-0) !important;
    margin: 0 0 6px !important;
  }
  .sb-persona__desc {
    font-size: 13.5px !important;
    color: var(--sb-ink-2) !important;
    line-height: 1.55 !important;
    margin: 0 0 16px !important;
    flex: 1;
    max-width: none !important;
  }
  .sb-persona__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    font-family: 'Geist Mono', monospace;
    letter-spacing: 0.04em;
    color: var(--sb-acc);
  }
  .sb-persona:hover .sb-persona__cta svg {
    transform: translateX(3px);
    transition: transform .12s;
  }
</style>
