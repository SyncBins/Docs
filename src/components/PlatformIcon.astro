---
/** Small brand marks for SyncBins client rows (Chrome, Edge, …). */
interface Props {
  name: 'chrome' | 'edge';
  size?: number;
}
const { name, size = 20 } = Astro.props;
const src = `/icons/${name}.svg`;
---

<img src={src} alt="" width={size} height={size} loading="lazy" decoding="async" aria-hidden="true" />
